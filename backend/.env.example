# Backend Environment Variables

# MongoDB Atlas connection string
MONGODB_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/skill2startup?retryWrites=true&w=majority

# Database name
DATABASE_NAME=skill2startup

# AI provider: gemini or groq
AI_PROVIDER=gemini

# Google Gemini API key (required when AI_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model name
GEMINI_MODEL=gemini-1.5-flash

# Groq API key (required when AI_PROVIDER=groq)
GROQ_API_KEY=your_groq_api_key_here

# Groq OpenAI-compatible model and base URL
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Comma-separated list of allowed CORS origins (frontend URLs)
# For production, set this to your Vercel deployment URL
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
