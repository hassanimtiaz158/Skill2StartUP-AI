# Backend Environment Variables

# MongoDB Atlas connection string
MONGODB_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/skill2startup?retryWrites=true&w=majority

# Database name
DATABASE_NAME=skill2startup

# AI provider: gemini or groq
AI_PROVIDER=gemini

# Google Gemini API key (required when AI_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model name
GEMINI_MODEL=gemini-1.5-flash

# Groq API key (required when AI_PROVIDER=groq)
GROQ_API_KEY=your_groq_api_key_here

# Groq OpenAI-compatible model and base URL
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Comma-separated list of allowed CORS origins (frontend URLs)
# For production, set this to your Vercel deployment URL
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend URL used by deployed frontend references
FRONTEND_URL=http://127.0.0.1:5173

# Email Configuration
# Mailjet (recommended — works via HTTPS, not blocked by firewalls)
# Sign up free at https://www.mailjet.com (6,000 emails/month, no credit card)
MAILJET_API_KEY=your_mailjet_api_key
MAILJET_SECRET_KEY=your_mailjet_secret_key
MAILJET_FROM=your.email@gmail.com
MAILJET_FROM_NAME=Skill2Startup AI

# SMTP fallback (only used if Mailjet is not configured or fails)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your.email@gmail.com
# SMTP_PASSWORD=your_app_password_here
# SMTP_FROM=your.email@gmail.com
